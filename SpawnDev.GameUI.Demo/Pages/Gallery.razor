@page "/gallery"
@using SpawnDev.BlazorJS
@using SpawnDev.BlazorJS.JSObjects
@using SpawnDev.GameUI
@using SpawnDev.GameUI.Elements
@using SpawnDev.GameUI.Input
@using SpawnDev.GameUI.Animation
@inject BlazorJSRuntime JS

<PageTitle>SpawnDev.GameUI - Element Gallery</PageTitle>

<h3>Element Gallery</h3>
<p style="color: #94a3b8;">WebGPU-rendered UI elements. All drawn on the canvas below - no HTML overlays.</p>

<div style="margin: 1rem 0;">
    <label style="color: #94a3b8; margin-right: 1rem;">Theme:</label>
    <button class="btn btn-sm @(_currentTheme == "dark" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetTheme("dark")'>Dark</button>
    <button class="btn btn-sm @(_currentTheme == "lost" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetTheme("lost")'>Lost Spawns</button>
    <button class="btn btn-sm @(_currentTheme == "aubs" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetTheme("aubs")'>AubsCraft</button>
</div>

<canvas @ref="_canvasRef" width="800" height="600"
        style="border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; background: #0a0a12; display: block;" />

<div style="margin-top: 0.5rem; color: #64748b; font-size: 0.85rem;">
    <span>Status: @_status</span>
</div>

@code {
    private ElementReference _canvasRef;
    private string _status = "Initializing WebGPU...";
    private string _currentTheme = "dark";
    private bool _initialized;

    // GameUI state
    private GameInput? _gameInput;
    private MouseKeyboardProvider? _mkProvider;
    private UIRenderer? _renderer;
    private UIElement? _rootElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized) return;
        _initialized = true;

        try
        {
            // Check for WebGPU
            using var gpu = JS.Get<GPU?>("navigator.gpu");
            if (gpu == null)
            {
                _status = "WebGPU not available in this browser.";
                StateHasChanged();
                return;
            }

            // Request adapter + device
            using var adapter = await gpu.RequestAdapter();
            if (adapter == null)
            {
                _status = "No WebGPU adapter found.";
                StateHasChanged();
                return;
            }

            using var device = await adapter.RequestDevice();
            using var queue = device.Queue;

            // Get canvas context
            using var canvas = new HTMLCanvasElement(_canvasRef);
            using var ctx = canvas.GetContext<GPUCanvasContext>("webgpu");
            var format = gpu.GetPreferredCanvasFormat();
            ctx.Configure(new GPUCanvasConfiguration
            {
                Device = device,
                Format = format,
                AlphaMode = "premultiplied",
            });

            // Initialize GameUI
            _gameInput = new GameInput();
            _mkProvider = new MouseKeyboardProvider();
            _mkProvider.Attach(_canvasRef);
            _gameInput.AddProvider(_mkProvider);

            // Initialize renderer
            _renderer = new UIRenderer();
            var fontAtlas = new SpawnDev.GameUI.Rendering.FontAtlas();
            fontAtlas.Init(device, queue);
            _renderer.Init(device, queue, fontAtlas, format);

            // Build the demo UI tree
            BuildDemoUI();

            _status = "WebGPU initialized. UI rendering on canvas.";
            StateHasChanged();

            // Start render loop
            // Note: in production, this would use requestAnimationFrame via BlazorJS
            // For the demo, we do a few frames to show the UI
            for (int frame = 0; frame < 3; frame++)
            {
                _gameInput.Poll();
                TweenManager.Global.Update(0.016f);
                _rootElement?.Update(_gameInput, 0.016f);

                using var texture = ctx.GetCurrentTexture();
                using var textureView = texture.CreateView();
                using var encoder = device.CreateCommandEncoder();

                // Clear the canvas
                using var clearPass = encoder.BeginRenderPass(new GPURenderPassDescriptor
                {
                    ColorAttachments = new[]
                    {
                        new GPURenderPassColorAttachment
                        {
                            View = textureView,
                            LoadOp = GPULoadOp.Clear,
                            StoreOp = GPUStoreOp.Store,
                            ClearValue = new GPUColorDict { R = 0.04, G = 0.04, B = 0.07, A = 1.0 },
                        }
                    }
                });
                clearPass.End();

                // Render UI
                _renderer.Begin(800, 600);
                _rootElement?.Draw(_renderer);
                _renderer.End(encoder, textureView);

                using var commandBuffer = encoder.Finish();
                queue.Submit(new[] { commandBuffer });

                await Task.Delay(16); // ~60fps
            }
        }
        catch (Exception ex)
        {
            _status = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

    private void BuildDemoUI()
    {
        var root = new UIAnchorPanel { Width = 800, Height = 600 };

        // Title
        var title = new UILabel { Text = "SpawnDev.GameUI Gallery", FontSize = FontSize.Title };
        root.AddAnchored(title, Anchor.TopCenter, offsetY: 20);

        // Left panel: controls
        var controls = new UIFlexPanel
        {
            Direction = FlexDirection.Column,
            Gap = 10,
            Width = 250,
            BackgroundColor = System.Drawing.Color.FromArgb(180, 20, 20, 35),
        };
        controls.AddChild(new UILabel { Text = "Controls", FontSize = FontSize.Heading });
        controls.AddChild(new UIButton { Text = "Click Me", Width = 220, Height = 36 });
        controls.AddChild(new UICheckbox { Text = "Enable VSync", Width = 220, Height = 24 });
        controls.AddChild(new UIToggle { Text = "Dark Mode" });
        controls.AddChild(new UISlider { Label = "Volume", Width = 220, Height = 40, Value = 0.7f });
        controls.AddChild(new UISeparator { Width = 220 });
        controls.AddChild(new UISlider { Label = "FOV", Width = 220, Height = 40, MinValue = 60, MaxValue = 120, Value = 90 });
        root.AddAnchored(controls, Anchor.TopLeft, offsetX: 20, offsetY: 70);

        // Right panel: game elements
        var gamePanel = new UIFlexPanel
        {
            Direction = FlexDirection.Column,
            Gap = 10,
            Width = 250,
            BackgroundColor = System.Drawing.Color.FromArgb(180, 20, 20, 35),
        };
        gamePanel.AddChild(new UILabel { Text = "Game UI", FontSize = FontSize.Heading });

        var healthBar = new UIProgressBar
        {
            Width = 220, Height = 22,
            Value = 0.75f,
            Label = "HP",
            ShowPercentage = true,
            LowColor = System.Drawing.Color.Orange,
            CriticalColor = System.Drawing.Color.Red,
        };
        gamePanel.AddChild(healthBar);

        var staminaBar = new UIProgressBar
        {
            Width = 220, Height = 18,
            Value = 0.45f,
            Label = "Stamina",
            FillColor = System.Drawing.Color.FromArgb(255, 80, 200, 120),
        };
        gamePanel.AddChild(staminaBar);

        gamePanel.AddChild(new UISeparator { Width = 220 });
        gamePanel.AddChild(new UILabel { Text = "Inventory (6x3)", FontSize = FontSize.Body });

        var grid = new UIGrid { Columns = 6, Rows = 3, CellSize = 34, CellGap = 3 };
        grid.AutoSizeGrid();
        grid.SetCell(0, label: "Axe");
        grid.SetCell(1, label: "Wood", labelColor: System.Drawing.Color.FromArgb(255, 139, 90, 43));
        grid.SetCell(2, label: "Stone");
        grid.SetCell(6, label: "Rope");
        grid.SetCell(7, label: "Cloth");
        grid.SetCell(12, label: "Med");
        gamePanel.AddChild(grid);

        root.AddAnchored(gamePanel, Anchor.TopRight, offsetX: -20, offsetY: 70);

        // Bottom: text input
        var chatInput = new UITextInput
        {
            Width = 400, Height = 32,
            Placeholder = "Type a message...",
        };
        root.AddAnchored(chatInput, Anchor.BottomCenter, offsetY: -20);

        _rootElement = root;
    }

    private void SetTheme(string theme)
    {
        _currentTheme = theme;
        UITheme.Current = theme switch
        {
            "lost" => UITheme.LostSpawns,
            "aubs" => UITheme.AubsCraft,
            _ => UITheme.Dark,
        };
        StateHasChanged();
    }

    public void Dispose()
    {
        _mkProvider?.Dispose();
        _renderer?.Dispose();
    }
}
